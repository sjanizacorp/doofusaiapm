{
  "name": "doofusai-spm",
  "version": "3.0.0",
  "description": "DoofusAI Security Posture Management platform",
  "private": true,
  "scripts": {
    "start": "bash start.sh",
    "start:native": "bash start.sh --native",
    "start:docker": "bash start.sh --docker",
    "start:build": "bash start.sh --docker --build",
    "stop": "bash stop.sh",
    "install:all": "npm install && cd ui && npm install && cd ..",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "node --watch api/server.js",
    "dev:ui": "cd ui && npx vite",
    "build": "cd ui && npx vite build",
    "test": "jest engine/ --runInBand",
    "uninstall": "bash uninstall.sh",
    "uninstall:purge": "bash uninstall.sh --purge"
  },
  "dependencies": {
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "sql.js": "^1.12.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}