# DoofusAI SPM Environment Configuration
# Copy to .env and fill in values. Never commit .env to source control.

# ── API server ────────────────────────────────────────────────────────────────
PORT=3001

# Database path (leave blank for default ./data/doofusai.db)
# DB_PATH=/absolute/path/to/doofusai.db

# ── LLM provider API keys ─────────────────────────────────────────────────────
# These are injected into check targets by name (api_key_env: "OPENAI_API_KEY")
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
GOOGLE_APPLICATION_CREDENTIALS=

# ── UI (Vite) ─────────────────────────────────────────────────────────────────
# When set, the UI calls the real API. When blank, the UI uses mock data.
VITE_API_URL=http://localhost:3001
